# ASTRO V1 - Yapay Zeka Ayarlari
# Bu dosyayi '.env' olarak kopyalayin ve icerigini doldurun.

# ==========================================
# 🤖 AI MOD & UYANDIRMA AYARLARI
# ==========================================
# "local" = API çağrısı yapılmaz, sadece STT test modu (varsayılan)
# "api"   = Gemini/OpenAI API'ye bağlanır, tam AI asistan olarak çalışır
AI_MODE="api"

# Robotun sadece bu kelimeyi duyduğunda uyanmasını sağlar
WAKE_WORD="hey astro"

# Sohbetin ne kadar süre açık kalacağı (saniye). 15 saniye idealdir.
CONVERSATION_TIMEOUT=15

# ==========================================
# 🧠 LLM API AYARLARI (AI_MODE="api" için gerekli)
# ==========================================
# Kullanacaginiz LLM saglayicisinin (OpenAI, Groq, Ollama vb.) API anahtari
AI_API_KEY="sk-..."

# Eger OpenAI harici bir API kullaniyorsaniz Base URL'i buraya yazin
# Orn: Ollama icin "http://localhost:11434/v1"
AI_BASE_URL="https://api.openai.com/v1"

# Kullanilacak Model Ismi
AI_MODEL="gpt-4o-mini"

# ==========================================
# 🎤 SPEECH TO TEXT (STT) AYARLARI
# ==========================================
# Hangi motoru kullanmak istiyorsunuz? Seçenekler: "vosk", "whisper" (API), "faster-whisper" (Local)
STT_ENGINE="faster-whisper"

# 1. YEREL VOSK KULLANIMI:
STT_VOSK_MODEL_PATH="/opt/vosk/vosk-model-small-tr-0.3"

# 2. WHISPER API KULLANIMI (Bulut STT):
STT_API_KEY="sk-BURAYA-WHISPER-API-ANAHTARINIZI-YAZIN"
STT_BASE_URL="https://api.openai.com/v1"
STT_WHISPER_MODEL="whisper-1"

# 3. YEREL FASTER-WHISPER KULLANIMI:
# Seçenekler: "large-v3", "distil-large-v3", "medium", "small", "base", "tiny"
# Cihaz: "cuda" (NVIDIA GPU / Jetson için önerilir) veya "cpu"
STT_FW_MODEL="distil-large-v3"
STT_FW_DEVICE="cuda"
STT_FW_COMPUTE_TYPE="float16" # "float16", "int8_float16", "int8"

# ==========================================
# 🔊 TEXT TO SPEECH (TTS) AYARLARI
# ==========================================
# Seçenekler: "elevenlabs" (Çok Doğal / Bulut), "edge-tts" (Doğal / İnternetli), "pyttsx3" (Robotik / Çevrimdışı), "gtts"
TTS_ENGINE="elevenlabs"

# Edge TTS Ses Seçenekleri: 
# Erkek: "tr-TR-AhmetNeural" | Kadın: "tr-TR-EmelNeural"
TTS_VOICE="tr-TR-AhmetNeural"

# ElevenLabs Ses Seçenekleri:
ELEVENLABS_API_KEY="your-elevenlabs-api-key-here"
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM" # Örn: Rachel veya Türkçe destekli herhangi bir voice ID
ELEVENLABS_MODEL_ID="eleven_multilingual_v2"
