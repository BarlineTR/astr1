# ASTRO V1 - Yapay Zeka Ayarlari
# Bu dosyayi '.env' olarak kopyalayin ve icerigini doldurun.

# Kullanacaginiz LLM saglayicisinin (OpenAI, Groq, Ollama vb.) API anahtari
AI_API_KEY="sk-..."

# Eger OpenAI harici bir API kullaniyorsaniz Base URL'i buraya yazin
# Orn: Ollama icin "http://localhost:11434/v1"
AI_BASE_URL="https://api.openai.com/v1"

# Kullanilacak Model Ismi
AI_MODEL="gpt-4o-mini"

# ==========================================
# 🎤 SPEECH TO TEXT (STT) AYARLARI
# ==========================================
# Hangi motoru kullanmak istiyorsunuz? Seçenekler: "vosk" veya "whisper"
STT_ENGINE="vosk"

# 1. YEREL VOSK KULLANIMI:
# Vosk modeli indirdiğiniz dizini buraya girin. 
# Örn: /opt/vosk/vosk-model-tr-0.3 (Büyük Model)
STT_VOSK_MODEL_PATH="/opt/vosk/vosk-model-small-tr-0.3"

# 2. WHISPER API KULLANIMI (Bulut STT):
# Eğer STT_ENGINE="whisper" yaptıysanız OpenAI/Groq API bilgilerini girin:
STT_API_KEY="sk-BURAYA-WHISPER-API-ANAHTARINIZI-YAZIN"
STT_BASE_URL="https://api.openai.com/v1"
STT_WHISPER_MODEL="whisper-1"
